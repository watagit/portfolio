---
import avatarImage from "../../../../public/avatar.png";

import SocialAccountIconList from "~/component/model/socialAccount/SocialAccountIconList/SocialAccountIconList.astro";
import { socialAccounts } from "~/data/socialAccount";
import { Image } from "astro:assets";
---

<header class="mx-auto flex w-11/12 justify-between py-3 sm:w-2/3">
  <a class="inline-flex items-center gap-3" href="/">
    <Image
      class="h-12 w-12 rounded-full sm:h-16 sm:w-16"
      src={avatarImage}
      width={100}
      height={100}
      alt="ロゴ画像"
      format="webp"
      quality={85}
      loading="eager"
    />
    <p class="text-lg leading-7 text-black">what_a_pon</p>
  </a>
  <SocialAccountIconList socialAccounts={socialAccounts} />
</header>
